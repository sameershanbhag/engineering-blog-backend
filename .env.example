# Copy to .env and fill in.
APP_ENV=local                # 'production' enforces a hardened config at startup
JWT_SECRET=change-me-to-a-long-random-string
INTERNAL_API_SECRET=shared-secret-the-frontend-sends-to-/auth/oauth
DATABASE_URL=sqlite:///./blog.db
# Managed Postgres later, e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
# CORS_ORIGINS=http://localhost:3000,https://your-frontend.example.com
